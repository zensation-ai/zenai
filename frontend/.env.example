# Frontend Environment Variables
# Copy this to .env and fill in your values

# API Key for backend authentication
# Get this from the backend API keys management or create one via:
# POST /api/keys with admin scope
VITE_API_KEY=your_api_key_here

# Backend API URL (for production)
# Leave empty for local development (uses Vite proxy)
# Set to Railway URL for production: https://ki-ab-production.up.railway.app
VITE_API_URL=
