# Frontend Environment Variables
# Copy this to .env and fill in your values
#
# PRODUCTION STACK:
# - Frontend: Vercel
# - Backend: Railway (https://ki-ab-production.up.railway.app)
# - Database: Supabase

# API Key for backend authentication
# Generate via backend or check existing keys in Supabase api_keys table
VITE_API_KEY=ab_live_...

# Backend API URL
# For Vercel production: https://ki-ab-production.up.railway.app
# For local development: leave empty (uses Vite proxy)
VITE_API_URL=

# Supabase Auth
# Get these from Supabase Dashboard → Settings → API
VITE_SUPABASE_URL=https://[PROJECT-REF].supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...
