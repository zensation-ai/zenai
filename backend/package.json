{
  "name": "zenai-backend",
  "version": "1.0.0",
  "description": "ZenAI - Enterprise AI Platform by ZenSation Enterprise Solutions",
  "homepage": "https://zensation.ai",
  "main": "dist/main.js",
  "scripts": {
    "dev": "ts-node-dev --respawn --transpile-only src/main.ts",
    "prebuild": "rm -rf dist",
    "build": "tsc",
    "start": "node dist/main.js",
    "db:init": "ts-node src/scripts/init-db.ts",
    "benchmark": "ts-node src/scripts/benchmark.ts",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "test:redis": "ts-node src/scripts/test-redis-v2.ts",
    "diagnose:redis": "ts-node diagnose-redis.ts",
    "test:supabase": "ts-node src/scripts/test-supabase.ts",
    "migrate:supabase": "ts-node src/scripts/migrate-to-supabase.ts",
    "create-ios-key": "ts-node scripts/create-ios-api-key.ts",
    "create-web-key": "ts-node scripts/create-web-api-key.ts",
    "generate-api-key": "ts-node generate-api-key.ts",
    "mcp:start": "ts-node src/mcp/server.ts",
    "test:integration": "jest --config jest.integration.config.js --forceExit",
    "security:audit": "ts-node scripts/security-audit.ts",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix"
  },
  "keywords": [
    "ai",
    "voice-memo",
    "ollama",
    "mistral",
    "pgvector"
