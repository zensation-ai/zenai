# PersonalAIBrain Backend - Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# Database Configuration
# ===========================================
# Option 1: Supabase (recommended for production)
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# Option 2: Railway (your current setup)
# DATABASE_URL=postgresql://user:password@host:5432/railway

# Supabase Configuration (for vector search & realtime features)
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_SERVICE_KEY=eyJhbGc...  # Get from Supabase Dashboard → Settings → API
SUPABASE_DB_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# For migration only (your current Railway URL)
RAILWAY_DATABASE_URL=postgresql://user:password@host:5432/railway

# ===========================================
# Server
# ===========================================
PORT=3000
NODE_ENV=production

# ===========================================
# AI Services
# ===========================================
# For local Ollama (development)
OLLAMA_URL=http://localhost:11434

# For cloud AI (production) - recommended for better reliability
# OpenAI Configuration - used for idea structuring, personalization, and embeddings
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini  # or gpt-4o for better quality (more expensive)

# Fallback priority: OpenAI → Ollama → Basic (no AI)

# Future AI providers (not yet implemented)
# ANTHROPIC_API_KEY=sk-...

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY=your-api-key-for-external-access

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# Redis Caching (Performance Boost)
# ===========================================
# Railway provides this automatically when you add Redis service
# For Railway: REDIS_URL is auto-configured
# For Upstash: redis://default:YOUR_PASSWORD@YOUR_ENDPOINT.upstash.io:6379
# For local testing: redis://localhost:6379
REDIS_URL=redis://localhost:6379

# Cache TTL settings (optional overrides)
# CACHE_DEFAULT_TTL=3600      # Default: 1 hour
# CACHE_EMBEDDING_TTL=604800  # Default: 7 days

# ===========================================
# Optional: File Storage
# ===========================================
# For S3-compatible storage (Railway volumes or external)
# S3_BUCKET=your-bucket
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
