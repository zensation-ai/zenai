# ===========================================
# ZenAI Backend - Environment Variables (Phase 41)
# ===========================================
# Copy this file to .env and fill in your values.
# Variables marked [REQUIRED] must be set for the backend to start.
# Variables marked [OPTIONAL] enable additional features.
#
# PRODUCTION STACK:
#   Database: Supabase (PostgreSQL with pgvector) - 4 schemas
#   Backend:  Railway
#   Frontend: Vercel
#   Cache:    Redis on Railway

# ===========================================
# Database [REQUIRED]
# ===========================================
# CRITICAL: Use port 6543 (Transaction Mode Pooler), NOT 5432 (Session Mode)
# Port 5432 = max ~1 connection, WILL crash with pool exhaustion
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:6543/postgres

# ===========================================
# AI [REQUIRED]
# ===========================================
ANTHROPIC_API_KEY=sk-ant-api03-...

# Claude model (default: claude-sonnet-4-20250514)
# CLAUDE_MODEL=claude-sonnet-4-20250514
# MAX_TOKENS=4096

# ===========================================
# Authentication [REQUIRED]
# ===========================================
# Generate with: cd backend && npm run create-web-key
VITE_API_KEY=ab_live_...

# ===========================================
# Server [OPTIONAL]
# ===========================================
PORT=3000
NODE_ENV=development

# CORS origins (comma-separated). Defaults to localhost if unset.
# ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://yourdomain.com

# Production API URL (used for Swagger server config)
# API_URL=https://your-backend.up.railway.app

# ===========================================
# Redis Cache [OPTIONAL]
# ===========================================
# If not set, caching is disabled (app works without it)
# REDIS_URL=redis://default:password@host:6379

# ===========================================
# Web Search [OPTIONAL]
# ===========================================
# Brave Search API (privacy-first). Falls back to DuckDuckGo if unset.
# Free tier: 2000 requests/month at https://brave.com/search/api/
# BRAVE_SEARCH_API_KEY=BSA...

# ===========================================
# Code Execution Sandbox [OPTIONAL]
# ===========================================
# ENABLE_CODE_EXECUTION=true
# CODE_EXECUTION_TIMEOUT=30000
# CODE_EXECUTION_MEMORY_LIMIT=256m
# CODE_SANDBOX_DIR=/tmp/code-sandbox

# Provider: auto-detected (docker local, judge0 production)
# EXECUTOR_PROVIDER=docker

# Judge0 (required for production code execution)
# JUDGE0_API_KEY=your-rapidapi-key
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# ===========================================
# GitHub Integration [OPTIONAL]
# ===========================================
# Personal Access Token - scopes: repo, read:user, read:org
# GITHUB_PERSONAL_ACCESS_TOKEN=ghp_...

# ===========================================
# Stripe (Business Manager) [OPTIONAL]
# ===========================================
# STRIPE_SECRET_KEY=sk_live_...
# STRIPE_WEBHOOK_SECRET=whsec_...

# ===========================================
# Google Analytics 4 [OPTIONAL]
# ===========================================
# GA4_PROPERTY_ID=123456789
# GA4_API_SECRET=...
# GOOGLE_SERVICE_ACCOUNT_EMAIL=...@...iam.gserviceaccount.com
# GOOGLE_SERVICE_ACCOUNT_KEY={"type":"service_account",...}

# ===========================================
# Google Search Console [OPTIONAL]
# ===========================================
# GOOGLE_CLIENT_ID=...apps.googleusercontent.com
# GOOGLE_CLIENT_SECRET=GOCSPX-...
# GOOGLE_REDIRECT_URI=https://your-backend.up.railway.app/api/business/connectors/google/callback
# GSC_SITE_URL=https://yourdomain.com

# ===========================================
# Email - Resend (Phase 38) [OPTIONAL]
# ===========================================
# RESEND_API_KEY=re_...
# RESEND_WEBHOOK_SECRET=whsec_...
# RESEND_DEFAULT_FROM=noreply@yourdomain.com

# ===========================================
# Memory Scheduler (HiMeS) [OPTIONAL]
# ===========================================
# CRON_TIMEZONE=Europe/Berlin
# CONSOLIDATION_SCHEDULE="0 2 * * *"
# DECAY_SCHEDULE="0 3 * * *"
# ENABLE_MEMORY_CONSOLIDATION=true
# ENABLE_MEMORY_DECAY=true

# ===========================================
# Google Maps (Phase 41) [OPTIONAL]
# ===========================================
# GOOGLE_MAPS_API_KEY=AIza...

# ===========================================
# Slack Integration [OPTIONAL]
# ===========================================
# SLACK_CLIENT_ID=...
# SLACK_CLIENT_SECRET=...
# SLACK_SIGNING_SECRET=...

# ===========================================
# Logging [OPTIONAL]
# ===========================================
# LOG_LEVEL=info
