# PersonalAIBrain Backend - Environment Variables
# Copy this to .env and fill in your values
#
# PRODUCTION STACK:
# - Database: Supabase (PostgreSQL with pgvector)
# - Backend: Railway
# - Frontend: Vercel
# - Cache: Redis on Railway

# ===========================================
# Database Configuration (Supabase)
# ===========================================
# Uses dual-schema architecture:
# - 'personal' schema for personal/private data
# - 'work' schema for work-related data
#
# Setup: Execute sql/migrate-public-to-schemas.sql in Supabase SQL Editor

DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-eu-central-1.pooler.supabase.com:5432/postgres
SUPABASE_URL=https://[PROJECT-REF].supabase.co
SUPABASE_ANON_KEY=eyJhbGc...  # Get from Supabase Dashboard → Settings → API
SUPABASE_SERVICE_KEY=eyJhbGc...  # Get from Supabase Dashboard → Settings → API

# ===========================================
# Server
# ===========================================
PORT=3000
NODE_ENV=production

# ===========================================
# AI Services
# ===========================================
# Primary LLM: Anthropic Claude
ANTHROPIC_API_KEY=sk-ant-api03-...

# OpenAI (for embeddings only - Claude doesn't support embeddings)
OPENAI_API_KEY=sk-proj-...

# Optional: Local Ollama (for development/offline use)
# OLLAMA_URL=http://localhost:11434

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY=your-api-key-for-external-access

# CORS - comma-separated list of allowed origins
# IMPORTANT: Add your Vercel frontend URL here for production
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173,https://your-frontend.vercel.app

# ===========================================
# Redis Caching (Railway)
# ===========================================
# Redis runs on Railway - get URL from Railway Dashboard
REDIS_URL=redis://default:[PASSWORD]@[HOST].proxy.rlwy.net:[PORT]

# Cache TTL settings (optional overrides)
# CACHE_DEFAULT_TTL=3600      # Default: 1 hour
# CACHE_EMBEDDING_TTL=604800  # Default: 7 days

# ===========================================
# Optional: File Storage
# ===========================================
# For S3-compatible storage (Railway volumes or external)
# S3_BUCKET=your-bucket
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# ===========================================
# Code Execution (Phase 31)
# ===========================================
# Enable/disable code execution feature
ENABLE_CODE_EXECUTION=true

# Execution limits
CODE_EXECUTION_TIMEOUT=30000          # 30 seconds
CODE_EXECUTION_MEMORY_LIMIT=256m      # 256 MB

# Provider selection (auto-detected if not set)
# EXECUTOR_PROVIDER=docker            # Force Docker (local/dev)
# EXECUTOR_PROVIDER=judge0            # Force Judge0 (production)

# Judge0 API (for production - get free key at rapidapi.com)
# JUDGE0_API_KEY=your-rapidapi-key
# JUDGE0_API_URL=https://judge0-ce.p.rapidapi.com
# JUDGE0_RAPIDAPI_HOST=judge0-ce.p.rapidapi.com

# Local Docker settings (development)
# CODE_SANDBOX_DIR=/tmp/code-sandbox

# ===========================================
# Web Search (Phase 31)
# ===========================================
# Brave Search API (privacy-first web search)
# Get free API key at: https://brave.com/search/api/
# Free tier: 2000 requests/month
BRAVE_SEARCH_API_KEY=BSA...your-key-here

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
