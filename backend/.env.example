# PersonalAIBrain Backend - Environment Variables
# Copy this to .env and fill in your values

# ===========================================
# Database (Railway provides these automatically)
# ===========================================
DATABASE_URL=postgresql://user:password@host:5432/railway
# Or individual settings:
# DB_HOST=localhost
# DB_PORT=5432
# DB_USER=postgres
# DB_PASSWORD=your_password
# DB_NAME=personal_ai

# ===========================================
# Server
# ===========================================
PORT=3000
NODE_ENV=production

# ===========================================
# AI Services
# ===========================================
# For local Ollama (development)
OLLAMA_URL=http://localhost:11434

# For cloud AI (production) - recommended for better reliability
# OpenAI Configuration - used for idea structuring, personalization, and embeddings
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_MODEL=gpt-4o-mini  # or gpt-4o for better quality (more expensive)

# Fallback priority: OpenAI → Ollama → Basic (no AI)

# Future AI providers (not yet implemented)
# ANTHROPIC_API_KEY=sk-...

# ===========================================
# Security
# ===========================================
# Generate with: openssl rand -hex 32
JWT_SECRET=your-super-secret-jwt-key-change-in-production
API_KEY=your-api-key-for-external-access

# CORS - comma-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000,http://localhost:8080

# ===========================================
# Optional: Redis (for caching)
# ===========================================
# REDIS_URL=redis://localhost:6379

# ===========================================
# Optional: File Storage
# ===========================================
# For S3-compatible storage (Railway volumes or external)
# S3_BUCKET=your-bucket
# S3_REGION=eu-central-1
# S3_ACCESS_KEY=...
# S3_SECRET_KEY=...

# ===========================================
# Logging
# ===========================================
LOG_LEVEL=info
